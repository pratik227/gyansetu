    <path android:pathData="M54,66 m-22,0 a22,21 0 1,0 44,0 a22,21 0 1,0 -44,0"
          android:fillColor="#A67242"/>
    <path android:pathData="M54,70 m-15,0 a15,15 0 1,0 30,0 a15,15 0 1,0 -30,0"
          android:fillColor="#FFE4C7"/>

    <!-- Head -->
    <path android:pathData="M54,42 m-23,0 a23,22 0 1,0 46,0 a23,22 0 1,0 -46,0"
          android:fillColor="#A67242"/>
