    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- Wings (slightly tucked so they survive the circular mask) -->
    <path android:pathData="M30,62 m-9,0 a9,14 0 1,0 18,0 a9,14 0 1,0 -18,0"
          android:fillColor="#8B5A2B"/>
    <path android:pathData="M78,62 m-9,0 a9,14 0 1,0 18,0 a9,14 0 1,0 -18,0"
          android:fillColor="#8B5A2B"/>

