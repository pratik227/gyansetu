<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive-icon foreground: owl mascot scaled to fit the 66×66 dp safe zone
     centred in the 108×108 dp canvas. Android masks the outer 18 dp on each
     side so all critical features (eyes, beak) stay inside the inner circle. -->
